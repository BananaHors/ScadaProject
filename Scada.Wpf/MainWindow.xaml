<Window x:Class="Scada.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scada.Wpf"
        mc:Ignorable="d"
        Title="SCADA - Substation Monitor" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Tags" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="AddButton" Content="Add" Width="80" Margin="20,0,0,0" Click="AddButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="TagsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="160"/>
                <DataGridTextColumn Header="Type"  Binding="{Binding Type}"  Width="70"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="110"/>
                <DataGridTextColumn Header="Units" Binding="{Binding Units}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
