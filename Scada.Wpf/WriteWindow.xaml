<Window x:Class="Scada.Wpf.WriteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Write value" Height="240" Width="340"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15">
        <TextBlock Text="Output tag (DO/AO)"/>
        <ComboBox x:Name="TagCombo" Margin="0,2,0,10"/>

        <TextBlock Text="Value"/>
        <TextBox x:Name="ValueBox" Margin="0,2,0,10"/>

        <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal">
            <Button Content="Write" Width="80" Click="WriteButton_Click"/>
            <Button Content="Cancel" Width="80" Margin="10,0,0,0" Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
