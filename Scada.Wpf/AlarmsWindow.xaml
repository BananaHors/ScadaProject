<Window x:Class="Scada.Wpf.AlarmsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alarm details" Height="300" Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="AlarmsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="90"/>
                <DataGridTextColumn Header="Threshold" Binding="{Binding Threshold}" Width="90"/>
                <DataGridTextColumn Header="State"     Binding="{Binding State}"     Width="120"/>
                <DataGridTextColumn Header="Message"   Binding="{Binding Message}"   Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="AcknowledgeButton" Grid.Row="2" Content="Acknowledge all"
                Width="130" HorizontalAlignment="Left" Margin="0,10,0,0"
                Click="AcknowledgeButton_Click"/>
    </Grid>
</Window>
