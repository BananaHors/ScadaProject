<Window x:Class="Scada.Wpf.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter AI history" Height="560" Width="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Leave a field blank to ignore it." FontStyle="Italic" Foreground="Gray" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Tag" VerticalAlignment="Center" Width="40"/>
                <ComboBox x:Name="TagCombo" Width="150" Margin="0,0,15,0"/>
                <TextBlock Text="From" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker x:Name="FromPicker" Width="120" Margin="0,0,15,0"/>
                <TextBlock Text="To" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker x:Name="ToPicker" Width="120"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Min value" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="MinBox" Width="80" Margin="0,0,15,0"/>
                <TextBlock Text="Max value" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="MaxBox" Width="80" Margin="0,0,15,0"/>
                <Button Content="Search" Width="90" Click="SearchButton_Click"/>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="ResultsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag"       Binding="{Binding TagName}"   Width="160"/>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="200"/>
                <DataGridTextColumn Header="Value"     Binding="{Binding Value}"     Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Button Content="Generate TXT" Width="120" Click="GenerateTxtButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
